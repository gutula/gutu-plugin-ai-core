{
  "name": "gutu-plugin-ai-core",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/builtin-plugins/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/builtin-plugins/ai-core build",
    "typecheck": "bun run --cwd framework/builtin-plugins/ai-core typecheck",
    "lint": "bun run --cwd framework/builtin-plugins/ai-core lint",
    "test": "bun run --cwd framework/builtin-plugins/ai-core test",
    "test:contracts": "bun run --cwd framework/builtin-plugins/ai-core test:contracts",
    "test:integration": "bun run --cwd framework/builtin-plugins/ai-core test:integration",
    "test:migrations": "bun run --cwd framework/builtin-plugins/ai-core test:migrations",
    "test:unit": "bun run --cwd framework/builtin-plugins/ai-core test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
